# Kira LLM — Environment Variables
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and should NEVER be committed.

# ── Server ────────────────────────────────────────────────────
# Port the Flask server listens on (default: 5000)
KIRA_PORT=5000

# Set to "production" to disable debug mode
FLASK_ENV=development

# ── Model paths ───────────────────────────────────────────────
# Path to the trained model checkpoint (relative to repo root)
# Populated automatically after running train.py
KIRA_CHECKPOINT=checkpoints/best.pt

# Path to the tokenizer vocabulary file
KIRA_TOKENIZER=data/tokenizer.json

# ── Generation settings ───────────────────────────────────────
KIRA_TEMPERATURE=0.8
KIRA_TOP_K=40
KIRA_TOP_P=0.95
KIRA_MAX_TOKENS=300
KIRA_REPETITION_PENALTY=1.1

# ── Memory ────────────────────────────────────────────────────
# Path to the SQLite memory database (created automatically)
KIRA_MEMORY_DB=memory.db
