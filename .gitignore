# Kira LLM — .gitignore

# ── Environment ───────────────────────────────────────────────
.env
*.env.local

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Virtual environments ──────────────────────────────────────
venv/
.venv/
env/
.env/

# ── Training artefacts ────────────────────────────────────────
# Checkpoints can be large — store them externally (e.g. Google Drive, HuggingFace)
checkpoints/*.pt
checkpoints/*.safetensors

# ── Data ──────────────────────────────────────────────────────
# Token caches (regenerated by prepare_data.py)
data/*_tokens.npy

# ── Runtime data ─────────────────────────────────────────────
memory.db
memory.json
knowledge.json
goals.json
conversation_history.json
user_profile.json
personality.json

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/

# ── IDE / OS ──────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
